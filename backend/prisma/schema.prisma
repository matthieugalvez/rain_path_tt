generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  output = "../generated/prisma"
}

model Workflow {
  id        String   @id @default(cuid())

  name      String	@unique

  nodesJson String
  edgesJson String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
